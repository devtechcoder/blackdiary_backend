{
  "compilerOptions": {
    "rootDir": "./src",

    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "moduleResolution": "node",

    "target": "es6",
    "module": "commonjs",
    "outDir": "dist",
    "sourceMap": false,
    "declaration": true,
    "skipLibCheck": true,
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "lib": ["es2017.object", "es2015", "es2017", "dom"]
  },
  "types": ["node"],
  "ts-node": {
    "files": true
  },
  "files": ["./node_modules/@types/node/index.d.ts"],
  "include": ["src/**/*.ts", "src/**/*.d.ts", "package.json"],
  "exclude": ["node_modules"]
}
